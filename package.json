{
  "name": "express-jenkins-starter",
  "version": "1.0.0",
  "description": "Express + TypeScript REST API boilerplate with Jenkins CI/CD pipeline, Docker, MongoDB, JWT auth and Jest  production-ready in minutes.",
  "keywords": [
    "express",
    "typescript",
    "jenkins",
    "ci-cd",
    "pipeline",
    "docker",
    "mongodb",
    "jwt",
    "rest-api",
    "boilerplate",
    "starter",
    "jest",
    "rbac",
    "helmet",
    "rate-limiting",
    "mongoose",
    "nodejs",
    "backend",
    "devops",
    "winston"
  ],
  "author": "TonNom <tonemail@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ton-compte/express-typescript-api"
  },
  "homepage": "https://github.com/ton-compte/express-typescript-api#readme",
  "bugs": {
    "url": "https://github.com/ton-compte/express-typescript-api/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "files": [
    "dist",
    "scripts",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "seed": "ts-node scripts/seed.ts",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}